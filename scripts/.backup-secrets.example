# Ting! — mẫu file secret cho backup Discord.
# Copy file này thành: scripts/.backup-secrets  (file đó đã được .gitignore, KHÔNG commit)
# rồi điền giá trị thật. Chạy local: npm run backup:discord

# Webhook Discord (giữ bí mật — ai có URL cũng gửi được vào kênh)
DISCORD_WEBHOOK_URL=

# Mật khẩu mã hoá backup — GIỮ THẬT KỸ. Mất key = không giải mã lại được backup.
BACKUP_KEY=

# Đường dẫn tới file service account JSON của project ting-d2c78 (chạy local).
# Trên CI (GitHub Actions) thì dùng secret FIREBASE_SERVICE_ACCOUNT thay cho dòng này.
SERVICE_ACCOUNT_PATH=./firebase-service-account.json
